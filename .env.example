# Appwrite — https://cloud.appwrite.io
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id

VITE_APPWRITE_USERS_COLLECTION=users
VITE_APPWRITE_PODCASTS_COLLECTION=podcasts
VITE_APPWRITE_FAVORITES_COLLECTION=favorites
VITE_APPWRITE_HISTORY_COLLECTION=history
VITE_APPWRITE_PROGRESS_COLLECTION=progress

# Один bucket — аудио/обложки с YouTube сохраняются сюда
VITE_APPWRITE_MEDIA_BUCKET=media

# Сервер (Vercel → Settings → Environment Variables), не VITE_
# RapidAPI: https://rapidapi.com/openapis/api/youtube-to-mp4-mp3 (бесплатно ~100 req/день)
RAPIDAPI_KEY=your_rapidapi_key
# RAPIDAPI_HOST=youtube-to-mp4-mp3.p.rapidapi.com

# Appwrite API key (Console → API Keys, scopes: storage write)
APPWRITE_API_KEY=your_server_api_key
APPWRITE_PROJECT_ID=your_project_id
# APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

VITE_APP_URL=https://your-app.vercel.app
VITE_DEV_MOCK_TELEGRAM=true
